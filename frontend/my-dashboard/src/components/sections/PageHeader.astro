---
import { PortableText } from '@portabletext/vue'

interface Props {
  title: string
  description: string
  image?: string 
  category?: { title: string }
  tags?: { title: string }[]
   body?: any[]
}

const { title, description, image, category, tags, body } = Astro.props
---

<section class="section">
  <h1 class="page_title">{title}</h1>
  <div class="portable-text-simple">
  <p>{description}</p>
 </div>

<div>{category && <span class="category">{category.title}</span>}

{tags && tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => (
        <span class="tag">{tag.title}</span>
      ))}
    </div>
  )}
</div>
</section>

<section class="poster_section">
 <div class="image_wrapper">{image && <img src={image} alt={title} />    }</div>
</section>

</section>
<section class="section">
  <div class="portable-text-simple">
  <PortableText value={body} />
  </div>
</section>


<style>
.page_title {
  display: flex;
  align-items: start;
  width: 100%;
  margin-bottom: var(--space-2);
  padding-left: var(--space-6);
}
.portable-text-simple {
  width: 98vw;
  padding-left: 40vw;
  padding-right: var(--space-6);
  margin-top: var(--space-4);
  line-height: 1.8;
}
img .image_wrapper{
  width: 100%;
  height: 40vh;
}
  .category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .tag {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
</style>