---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'
import  ImageSlider  from '../ui/ImageSlider.vue'

interface Props {
  type?: string
  documentation?: {
    posterImage?: string
    text?: any[]
    images?: { url: string; caption?: string }[]
  }
}


const { type, documentation } = Astro.props
const posterImage = documentation?.posterImage

const sliderImages = documentation?.images?.map(img => ({
  url: img.url,
  alt: img.caption ?? ''
})) ?? []

const typeLabels: Record<string, string> = {
  'workshop': 'Workshop',
  'event': 'Event',
  'session': 'Session',
  'field-work': 'Field Work',
}

const typeDisplay = type ? (typeLabels[type] ?? type) : 'Documentation'
---

{documentation && (documentation.posterImage || documentation.text || documentation.images?.length) && (
<section>
  
     {posterImage && (
      <div class="poster">
        <img src={posterImage} alt="" />
      </div>
    )}

<div class="container_grid">
   
    <h2 class="heading_l">{typeDisplay}</h2>
  
    <div class="portable_text">{documentation.text && ( <PortableTextRenderer body={documentation.text} client:load />
    )}
    </div>
</div>

 {sliderImages.length > 0 && (
      <ImageSlider images={sliderImages} client:load />
    )}

</section>
)}


<style>
.container_grid {
  display: grid;
  grid-template-columns: 15vw 15vw 1fr 1fr 1fr;
  grid-template-rows: 4rem auto;
  gap: 2rem;
  grid-template-areas:
    "a a-2 a-2 a-3 a-3"
    "a a-4 a-5 a-5 a-5";
  padding: var(--space-16) var(--space-4) 0 var(--space-4);
}

.heading_l {
  grid-area: a-2;
}

.portable_text {
  grid-area: a-5; 
  padding-bottom: var(--space-16);
}


  
</style>