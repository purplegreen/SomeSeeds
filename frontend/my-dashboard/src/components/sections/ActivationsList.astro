---
interface Props {
  activations: {
    title: string
    slug: string
    type?: string
    status?: string
    startDate?: string
    endDate?: string
    location?: { venue?: string; city?: string; country?: string }
    coverImage?: string
    hostingInstitutions?: { name: string; logo?: string; url?: string }[]
  }[]
}

const { activations } = Astro.props
---

{activations.length === 0 ? (
  <section class="section">
    <p class="no-content">No activations yet.</p>
  </section>
) : (
  <section class="section">
    <div class="activations-list">
      {activations.map(activation => (
        <a href={`/activations/${activation.slug}`} class="activation-card">

          {activation.coverImage && (
            <div class="activation-card__image">
              <img src={activation.coverImage} alt={activation.title} />
            </div>
          )}

          <div class="activation-card__body">

            <div class="activation-card__meta">
              {activation.type && (
                <span class="tag">{activation.type}</span>
              )}
              {activation.status && (
                <span class={`tag tag--${activation.status}`}>
                  {activation.status}
                </span>
              )}
            </div>

            <h3 class="activation-card__title heading-s">
              {activation.title}
            </h3>

            {activation.startDate && (
              <p class="activation-card__date">
                {new Date(activation.startDate).toLocaleDateString("en-GB", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
                {activation.endDate && (
                  ` — ${new Date(activation.endDate).toLocaleDateString("en-GB", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}`
                )}
              </p>
            )}

            {activation.location?.city && (
              <p class="activation-card__location">
                {[
                  activation.location.venue,
                  activation.location.city,
                  activation.location.country
                ].filter(Boolean).join(", ")}
              </p>
            )}

            {activation.hostingInstitutions && activation.hostingInstitutions.length > 0 && (
              <div class="activation-card__institutions">
                {activation.hostingInstitutions.map(i => (
                  <span class="institution-name">{i.name}</span>
                ))}
              </div>
            )}

          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
.activations-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-8);
}

.activation-card {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  flex: 1 1 calc(50% - var(--space-8));
  min-width: 280px;
  gap: 1rem;
  transition: opacity 0.15s ease;
}

.activation-card:hover {
  opacity: 0.7;
}

.activation-card__image img {
  width: 100%;
  height: auto;
  display: block;
}

.activation-card__meta {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.activation-card__title {
  margin: 0.5rem 0;
}

.activation-card__date,
.activation-card__location {
  font-size: var(--text-s);
  margin: 0;
  opacity: 0.6;
}

.activation-card__institutions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.25rem;
}

.institution-name {
  font-size: var(--text-s);
  opacity: 0.6;
}

.no-content {
  opacity: 0.4;
  font-size: var(--text-s);
}

@media (max-width: 768px) {
  .activation-card {
    flex: 1 1 100%;
  }
}
</style>