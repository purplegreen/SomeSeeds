---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'
import CategoryTag from '../ui/CategoryTag.astro'
import TagPill from '../ui/TagPill.astro'

interface Props {
  title: string
  description: string
  image?: string 
  category?: { title: string }
  tags?: { title: string }[]
  body?: any[]
}


const { title, description, image, category, tags, body } = Astro.props
---

<section class="section-header">
  <h1 class="page_title">{title}</h1>
  <div class="image_wrapper">{image && <img src={image} alt={title} />}</div>
</section>
  <div class="portable-text-simple">
  <p>{description}</p>
 </div>

<div class="tags_cat__box">
  {category && <CategoryTag label={category.title} />}
  {tags && tags.length > 0 && (
    tags.map(tag => <TagPill label={tag.title} />)
  )}
</div>

</section>

<section class="section">
  <div class="portable-text-simple">
  <PortableTextRenderer body={body} client:load />
  </div>
</section>


<style>
.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  width: 100%;
  padding: var(--space-8);
  gap: var(--space-8);
}    
.page_title {
  flex: 1;
  font-size: var(--text-5xl);
  font-weight: var(--font-weight-bold);
}
.image_wrapper {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}
.image_wrapper img {
  width: 100%;
  max-height: 85vh;
  height: auto;
  width: auto;
  display: block;
}

.tags_cat__box {
  display: flex;
  align-items: center;
  padding-left: 40vw;
  gap: var(--space-4);
  margin-top: var(--space-2);
}

  @media (max-width: 768px) {
  .page_title {
  padding-left: var(--space-1);
}
  }
  @media (max-width: 480px) {

}
</style>