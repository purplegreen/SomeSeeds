---
import CategoryTag from './CategoryTag.astro'
import TagPill from './TagPill.astro'

interface Props {
  title: string
  slug: string
  type?: string
  status?: string
  startDate?: string
  endDate?: string
  location?: { venue?: string; city?: string; country?: string }
  coverImage?: string
  partnerInstitutions?: { name: string; logo?: string; url?: string }[]
  categories?: { title: string }[]
  tags?: { title: string }[]
}

const {
  title,
  slug,
  type,
  status,
  startDate,
  endDate,
  location,
  coverImage,
  partnerInstitutions,
  categories,
  tags,
} = Astro.props

// ── Date formatting ───────────────────────────────────────
const formatDate = (dateStr: string) =>
  new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  })

const formatTime = (dateStr: string) =>
  new Date(dateStr).toLocaleTimeString('en-GB', {
    hour: '2-digit',
    minute: '2-digit',
  })

const hasTime = (dateStr: string) => {
  const d = new Date(dateStr)
  return d.getHours() !== 0 || d.getMinutes() !== 0
}

const isSameDay = startDate && endDate &&
  new Date(startDate).toDateString() === new Date(endDate).toDateString()

const isMultiDay = startDate && endDate && !isSameDay

let dateDisplay = ''

if (startDate && endDate) {
  if (isMultiDay) {
    // 12–14 Nov 2025
    const start = new Date(startDate)
    const end = new Date(endDate)
    const startDay = start.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })
    const endFull = end.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
    dateDisplay = `${startDay}–${endFull}`
  } else {
    // Same day: 12 Nov 2025 · 14:00–18:00
    dateDisplay = formatDate(startDate)
    if (hasTime(startDate)) {
      dateDisplay += ` · ${formatTime(startDate)}`
      if (hasTime(endDate)) dateDisplay += `–${formatTime(endDate)}`
    }
  }
} else if (startDate) {
  dateDisplay = formatDate(startDate)
  if (hasTime(startDate)) dateDisplay += ` · ${formatTime(startDate)}`
}

// ── Location ──────────────────────────────────────────────
const locationDisplay = location
  ? [location.venue, location.city, location.country].filter(Boolean).join(', ')
  : null
---

<a href={`/activations/${slug}`} class="activation-card">

  {coverImage && (
    <div class="activation-card__image">
      <img src={coverImage} alt={title} />
    </div>
  )}

  <div class="activation-card__body">

    <div class="activation-card__tags">
      {type && <CategoryTag label={type} />}
      {status && <TagPill label={status} />}
    </div>

    <h3 class="activation-card__title">{title}</h3>

    {dateDisplay && (
      <p class="activation-card__date">{dateDisplay}</p>
    )}

    {locationDisplay && (
      <p class="activation-card__location">{locationDisplay}</p>
    )}

    {partnerInstitutions && partnerInstitutions.length > 0 && (
      <div class="activation-card__partners">
        {partnerInstitutions.map(p => (
          p.logo && <img src={p.logo} alt={p.name} class="activation-card__partner-logo" />
        ))}
      </div>
    )}

    {(categories?.length || tags?.length) && (
      <div class="activation-card__taxonomy">
        {categories?.map(c => <CategoryTag label={c.title} />)}
        {tags?.map(t => <TagPill label={t.title} />)}
      </div>
    )}

  </div>
</a>

<style>
.activation-card {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 0;
  transition: opacity 0.15s ease;
  overflow: hidden;
  min-width: 0; 
  border: 1px solid blue;
}

.activation-card:hover {
  opacity: 0.7;
}

.activation-card__image {
  width: 100%;  
  max-width: 48vw;
  height: auto;
  display: block;
}

.activation-card__image img {
  width: 100%;
  height: 100%;
  display: block;
}

.activation-card__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-top: var(--space-3);
}

.activation-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.activation-card__title {
  font-size: var(--text-m);
  font-weight: 600;
  margin: 0;
  line-height: var(--line-height-snug);
}

.activation-card__date,
.activation-card__location {
  font-size: var(--text-s);
  margin: 0;
  opacity: 0.6;
}

.activation-card__partners {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  align-items: center;
  margin-top: var(--space-1);
}

.activation-card__partner-logo {
  height: 1.5rem;
  width: auto;
}

.activation-card__taxonomy {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-1);
}
</style>