---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'
import ImageSlider from '../ui/ImageSlider.vue'

interface Props {
  type?: string
  documentation?: {
    posterImage?: string
    text?: any[]
    images?: { url: string; caption?: string }[]
  }
}

const { type, documentation } = Astro.props
const posterImage = documentation?.posterImage

const sliderImages = documentation?.images?.map(img => ({
  url: img.url,
  alt: img.caption ?? ''
})) ?? []
---

{documentation && (documentation.posterImage || documentation.text || documentation.images?.length) && (
 <section class="section">
    <h2 class="heading-m go_side">{type ?? 'Documentation'}</h2>
  </section>
  <section class="section_poster">
     {posterImage && (
      <div class="poster">
        <img src={posterImage} alt="" />
      </div>
    )}
  </section>

 <section class="section">
    {documentation.text && (
      <div class="portable-text-simple go_side">
        <PortableTextRenderer body={documentation.text} client:load />
      </div>
    )}

   </section>
 <section class="section">
 {sliderImages.length > 0 && (
      <ImageSlider images={sliderImages} client:load />
    )}

  </section>
)}

<style>
</style>