---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'

interface Props {
  research?: {
    text?: any[]
    images?: { asset: { url: string }; caption?: string }[]
    links?: { label?: string; url: string }[]
  }
}

const { research } = Astro.props
---

{research && (research.text || research.images?.length || research.links?.length) && (
  <section class="section">
    <h2 class="heading-m">Research</h2>

    {research.text && (
      <div class="portable-text-simple">
        <PortableTextRenderer body={research.text} client:load />
      </div>
    )}

    {research.images && research.images.length > 0 && (
      <div class="image-gallery">
        {research.images.map(img => (
          <figure>
            <img src={img.asset.url} alt={img.caption ?? ""} />
            {img.caption && <figcaption>{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    {research.links && research.links.length > 0 && (
      <ul class="link-list">
        {research.links.map(link => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.label ?? link.url}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
)}

<style>
.image-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-top: var(--space-8);
}

.image-gallery figure {
  margin: 0;
  flex: 1 1 calc(50% - var(--space-4));
  min-width: 240px;
}

.image-gallery img {
  width: 100%;
  height: auto;
  display: block;
}

.image-gallery figcaption {
  font-size: var(--text-s);
  opacity: 0.6;
  margin-top: var(--space-2);
}

.link-list {
  margin-top: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-left: var(--space-4);
}

.link-list a {
  font-size: var(--text-s);
}
</style>