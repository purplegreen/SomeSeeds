---
import ActivationCard from '../ui/ActivationCard.astro'

interface Props {
  activations: {
    title: string
    slug: string
    type?: string
    status?: string
    startDate?: string
    endDate?: string
    location?: { venue?: string; city?: string; country?: string }
    coverImage?: string
    partnerInstitutions?: { name: string; logo?: string; url?: string }[]
    categories?: { title: string }[]
    tags?: { title: string }[]
  }[]
}

const { activations } = Astro.props
---

{activations.length === 0 ? (
  <section class="section">
    <p class="no-content">No activations yet.</p>
  </section>
) : (
  <section class="section">
    <div class="activations-grid">
      {activations.map(activation => (
        <ActivationCard {...activation} />
      ))}
    </div>
  </section>
)}

<style>
.activations-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-8);
    border: 2px solid red;
}

.activations-grid > * {
  flex: 1 1 calc(50% - var(--space-8));
  min-width: 280px;

}

.no-content {
  opacity: 0.4;
  font-size: var(--text-s);
}

@media (max-width: 768px) {
  .activations-grid > * {
    flex: 1 1 100%;
  }
}
</style>