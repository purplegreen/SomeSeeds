---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'
import ImageSlider from '../ui/ImageSlider.vue'

interface Props {
  documentation?: {
    text?: any[]
    images?: { url: string; caption?: string }[]
  }
}

const { documentation } = Astro.props


const sliderImages = documentation?.images?.map(img => ({
  url: img.url,
  alt: img.caption ?? ''
})) ?? []
---

{documentation && (documentation.text || documentation.images?.length) && (
  <section class="section">
    <h2 class="heading-m">Documentation</h2>

    {documentation.text && (
      <div class="portable-text-simple go_side">
        <PortableTextRenderer body={documentation.text} client:load />
      </div>
    )}

 {sliderImages.length > 0 && (
      <ImageSlider images={sliderImages} client:load />
    )}

  </section>
)}

<style>
.image-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-top: var(--space-8);
}

.image-gallery figure {
  margin: 0;
  flex: 1 1 calc(50% - var(--space-4));
  min-width: 240px;
}

.image-gallery img {
  width: 100%;
  height: auto;
  display: block;
}

.image-gallery figcaption {
  font-size: var(--text-s);
  opacity: 0.6;
  margin-top: var(--space-2);
}
</style>