---
import { getAllActivations, getActivation } from "../../lib/sanity"
import Layout from "../../layouts/Layout.astro"
import ContentHeader from "../../components/sections/ContentHeader.astro"
import ActivationResearch from "../../components/sections/ActivationResearch.astro"
import ActivationDocumentation from "../../components/sections/ActivationDocumentation.astro"
import ActivationOutcomes from "../../components/sections/ActivationOutcomes.astro"

export async function getStaticPaths() {
  const activations = await getAllActivations()
  return activations.map(a => ({
    params: { slug: a.slug },
  }))
}

const { slug } = Astro.params
const activation = await getActivation(slug)
console.log("documentation images:", JSON.stringify(activation.documentation?.images, null, 2))
---

<Layout>
  <ContentHeader
    title={activation.title}
    description={activation.summary}
    image={activation.coverImage}
    tags={activation.tags}
    category={activation.categories?.[0]}
  />

  <ActivationResearch research={activation.research} />
  <ActivationDocumentation documentation={activation.documentation} />
  <ActivationOutcomes outcomes={activation.outcomes} />
</Layout>