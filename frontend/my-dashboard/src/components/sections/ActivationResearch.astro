---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'

interface Props {
  research?: {
    text?: any[]
    images?: { url: string; caption?: string }[]
    links?: { label?: string; url: string }[]
  }
}

const { research } = Astro.props
---

{research && (research.text || research.images?.length || research.links?.length) && (
  <section>

<div class="container_grid">
    <h2 class="heading_l">Research</h2>
<div class="portable_text">
    {research.text && (
        <PortableTextRenderer body={research.text} client:load /> 
    )}
    </div>
</div>
{/*
    {research.images && research.images.length > 0 && (
      <div class="image-gallery">
        {research.images.map(img => (
          <figure>
            <img src={img.url} alt={img.caption ?? ""} />
            {img.caption && <figcaption>{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
      */}

    {/* wrap the map in the gallery div */}
<div class="image-gallery">
  {research.images?.map((img, i) => (
    <figure>
      <a href={`#img-${i}`}>
        <img src={img.url} alt={img.caption ?? ""} />
      </a>
      {img.caption && <figcaption>{img.caption}</figcaption>}

      <div class="lightbox" id={`img-${i}`}>
        <a href="#gallery" class="lightbox__close">✕</a>
        <img src={img.url} alt={img.caption ?? ""} />
      </div>
    </figure>
  ))}
</div>

    {research.links && research.links.length > 0 && (
      <ul class="link-list">
        {research.links.map(link => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.label ?? link.url}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
)}

<style>


.container_grid {
  display: grid;
  grid-template-columns: 15vw 15vw 1fr 1fr 1fr;
  grid-template-rows: 4rem auto;
  gap: 4rem 2rem;
  grid-template-areas:
    "a a-2 a-2 a-3 a-3"
    "a a-4 a-5 a-5 a-5";
  padding: var(--space-16) var(--space-4) 0 var(--space-4);
}

.heading_l {
  grid-area: a-2;
}

.portable_text {
  grid-area: a-5; 
  padding-bottom: var(--space-16);
}

.image-gallery {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 25vw; /* auto-generates rows as needed */
  gap: 0.75rem;
}


css.image-gallery figure {
  position: relative;  /* needed for figcaption absolute positioning */
  overflow: hidden;    /* clips the zoom effect */
  margin: 0;
  border-radius: var(--radius-xl);
}

/* Repeating bento pattern every 6 images */
.image-gallery figure:nth-child(6n + 1) {
  grid-column: span 2;
  grid-row: span 2; /* big square */
}
.image-gallery figure:nth-child(6n + 4) {
  grid-column: span 2;
  grid-row: span 2; /* big square */
}

.image-gallery figure img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.image-gallery figure:hover img {
  transform: scale(1.04);
}

/* Caption appears on hover */
.image-gallery figcaption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0.5rem 0.75rem;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: var(--text-xs);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.image-gallery figure:hover figcaption {
  opacity: 1;
}

.link-list {
  margin-top: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-left: var(--space-4);
}

.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 999;
  justify-content: center;
  align-items: center;
}

/* Opens when the id is targeted via the URL hash */
.lightbox:target {
  display: flex;
}

.lightbox img {
  max-width: 90vw;
  max-height: 90vh;
  object-fit: contain;
  border-radius: var(--radius-xl);
}

.lightbox__close {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  color: white;
  font-size: 1.5rem;
  text-decoration: none;
}

.link-list a {
  font-size: var(--text-m);
}
</style>