---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'
import CategoryTag from '../ui/CategoryTag.astro'
import TagPill from '../ui/TagPill.astro'

interface Props {
  title: string
  description?: string
  image?: string 
  category?: { title: string }
  tags?: { title: string }[]
  body?: any[]
  startDate?: string
  startTime?: string
  endDate?: string
  endTime?: string
  location?: { venue?: string; city?: string; country?: string }
  partnerInstitutions?: { name?: string; logo?: string; url?: string }[]
}

const { title, description, image, category, tags, body, startDate, startTime, endDate, endTime, location, partnerInstitutions } = Astro.props

// ── Date formatting ───────────────────────────────────────
const formatDate = (dateStr: string) => {
  if (!dateStr) return ''
  const d = new Date(dateStr)
  return d.toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
    timeZone: 'UTC'
  })
}

const isSameDay = startDate && endDate &&
  new Date(startDate).toDateString() === new Date(endDate).toDateString()
const isMultiDay = startDate && endDate && !isSameDay

let dateDisplay = ''
if (startDate) {
  if (isMultiDay) {
    const startDay = new Date(startDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', timeZone: 'UTC' })
    const endFull = new Date(endDate!).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC' })
    dateDisplay = `${startDay}–${endFull}`
  } else {
    dateDisplay = formatDate(startDate)
    if (startTime) {
      dateDisplay += ` · ${startTime}`
      if (endTime) dateDisplay += `–${endTime}`
    }
  }
}

const locationDisplay = location
  ? [location.venue, location.city, location.country].filter(Boolean).join(', ')
  : null
---

<section class="section-header">
  <h1 class=".heading_6xl">{title}</h1>
  <div class="image_wrapper">{image && <img src={image} alt={title} />}</div>
</section>

{(dateDisplay || locationDisplay) && (
  <div class="activation-meta go_side">
    {dateDisplay && <span class="activation-meta__date">{dateDisplay}</span>}
    {locationDisplay && <span class="activation-meta__location">{locationDisplay}</span>}
  </div>
)}

{partnerInstitutions && partnerInstitutions.length > 0 && (
  <div class="partner-institutions go_side">
    {partnerInstitutions.map(p => (
      <div class="partner">
        {p.logo && <img src={p.logo} alt={p.name ?? ''} class="partner__logo" />}
        {p.name && <span class="partner__name">{p.name}</span>}
      </div>
    ))}
  </div>
)}

{description && (
  <div class="portable-text-simple go_side">
    <p>{description}</p>
  </div>
)}

<div class="tags_cat__box go_side">
  {category && <CategoryTag label={category.title} />}
  {tags && tags.length > 0 && (
    tags.map(tag => <TagPill label={tag.title} />)
  )}
</div>

{body && (
  <div class="portable-text-simple go_side">
    <PortableTextRenderer body={body} client:load />
  </div>
)}

<style>
.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  width: 100%;
  padding: var(--space-8);
  gap: var(--space-8);
}

.partner-institutions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-6);
  margin-top: var(--space-4);
}

.partner {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.partner__logo {
  height: 2rem;
  width: auto;
}

.partner__name {
  font-size: var(--text-m);
  opacity: 0.7;
}

.heading_6xl {
  flex: 1;
  font-size: var(--text-5xl);
  font-weight: var(--font-weight-bold);
}

.image_wrapper {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}

.image_wrapper img {
  max-height: 85vh;
  height: auto;
  width: auto;
  display: block;
}

.activation-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-top: var(--space-2);
  font-size: var(--text-m);
}

.activation-meta__location {
  opacity: 0.6;
}

.tags_cat__box {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-4);
  margin-top: var(--space-2);
}

@media (max-width: 768px) {
  .heading_6xl {
    padding-left: var(--space-1);
  }
}
</style>