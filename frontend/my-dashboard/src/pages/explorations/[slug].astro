---
import { getExplorations, getExploration, getActivationsByExploration } from "../../lib/sanity"
import Layout from "../../layouts/Layout.astro"
import ContentHeader from "../../components/sections/ContentHeader.astro"
import ActivationsList from "../../components/sections/ActivationsList.astro"
import PortableTextRenderer from "../../components/ui/PortableTextRenderer.vue"

export async function getStaticPaths() {
  const explorations = await getExplorations()
  return explorations.map(e => ({
    params: { slug: e.slug },
  }))
}

const { slug } = Astro.params
const exploration = await getExploration(slug)
const activations = await getActivationsByExploration(exploration._id)
console.log("activations count:", activations.length)
console.log("activations:", JSON.stringify(activations, null, 2))
---

<Layout>
  <ContentHeader
    title={exploration.title}
    description={exploration.summary}
    image={exploration.coverImage}
    category={exploration.category}
    tags={exploration.tags}
  />

  {exploration.body && (
    <section class="section">
      <div class="portable-text-simple">
        <PortableTextRenderer body={exploration.body} client:load />
      </div>
    </section>
  )}

  {exploration.collaborators && exploration.collaborators.length > 0 && (
    <section class="section">
      <h2 class="heading-m">Collaborators</h2>
      <div class="collaborators">
        {exploration.collaborators.map(c => (
          <div class="collaborator">
            {c.logo && <img src={c.logo} alt={c.name} />}
            {c.url
              ? <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
              : <span>{c.name}</span>
            }
          </div>
        ))}
      </div>
    </section>
  )}

  <ActivationsList activations={activations} />
</Layout>

<style>
.collaborators {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  align-items: center;
}

.collaborator {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.collaborator img {
  height: 2rem;
  width: auto;
}
</style>