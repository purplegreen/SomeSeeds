---
import PortableTextRenderer from '../ui/PortableTextRenderer.vue'
import CategoryTag from '../ui/CategoryTag.astro'
import TagPill from '../ui/TagPill.astro'

interface Props {
  title: string
  description?: string
  image?: string 
  category?: { title: string }
  tags?: { title: string }[]
  credits?: any[]
  startDate?: string
  startTime?: string
  endDate?: string
  endTime?: string
  location?: { venue?: string; city?: string; country?: string }
  partnerInstitutions?: { name?: string; logo?: string; url?: string }[]
}

const { title, image, category, tags, credits, startDate, startTime, endDate, endTime, location, partnerInstitutions } = Astro.props

// ── Date formatting ───────────────────────────────────────
const formatDate = (dateStr: string) => {
  if (!dateStr) return ''
  const d = new Date(dateStr)
  return d.toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric',
    timeZone: 'UTC'
  })
}

const isSameDay = startDate && endDate &&
  new Date(startDate).toDateString() === new Date(endDate).toDateString()
const isMultiDay = startDate && endDate && !isSameDay

let dateDisplay = ''
if (startDate) {
  if (isMultiDay) {
    const startDay = new Date(startDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', timeZone: 'UTC' })
    const endFull = new Date(endDate!).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC' })
    dateDisplay = `${startDay}–${endFull}`
  } else {
    dateDisplay = formatDate(startDate)
    if (startTime) {
      dateDisplay += ` · ${startTime}`
      if (endTime) dateDisplay += `–${endTime}`
    }
  }
}

const locationDisplay = location
  ? [location.venue, location.city, location.country].filter(Boolean).join(', ')
  : null
---


<section class="header_grid">

<h1 class="page_title title_in_grid">{title}</h1>

<div class="image_box">{image && <img src={image} alt={title} />}</div>

<div class="container">
{(dateDisplay || locationDisplay) && (
  <div class="date_location__box">
    {dateDisplay && <h5><span class="date">{dateDisplay}</span></h5>}
    {locationDisplay && <h3><span class="location">{locationDisplay}</span></h3>}
  </div>
)}



{credits && (
  <div class="portable-text-simple">
    <PortableTextRenderer body={credits} client:load />
  </div>
)}

{partnerInstitutions && partnerInstitutions.length > 0 && (
  <div class="partners_box">
    {partnerInstitutions.map(p => (
      <div class="item_partner__box">
        {p.logo && <img src={p.logo} alt={p.name ?? ''} class="partner__logo" />}
      </div>
    ))}
  </div>
)}

<div class="tags_cat__box">
  {category && <CategoryTag label={category.title} />}
  {tags && tags.length > 0 && (
    tags.map(tag => <TagPill label={tag.title} />)
  )}
</div>
</div>

</section>

<style>
.header_grid{
  display: grid;
  grid-template-columns: 20vw 20vw 1fr 1fr;
  grid-template-rows: 1fr auto;
  gap: 1rem;
  grid-template-areas:
  "box-1 box-1 box-3 box-3"
  "box-1 box-1 box-5 box-5";
  padding: var(--space-16) var(--space-4);
}
.image_box {
  display: flex;
  flex: 1;
  min-width: 0;
  justify-content: center;
  align-items: center;
  grid-area: box-1;
}
.image_box img {
  width: auto;
  height: 98vh;
  width: auto;
  display: block;
}
.title_in_grid {
 grid-area: box-3;
}
.container {
  grid-area: box-5;
}
.date_location__box{
  display: flex;
  flex-direction: column;
  padding: var(--space-4) 0;
}
.partners_box{
  display: flex;
  flex-wrap: wrap;
  flex-direction: row;
  justify-content: center;
  gap: var(--space-4);
  padding: var(--space-8) 0;
}

.partner__logo {
 width: auto;
 height: 4rem;
}

.tags_cat__box{  display: flex;
  flex-wrap: wrap;
  flex-direction: row;
  justify-content: start;
  gap: var(--space-4);
  padding: var(--space-8) 0; 
}



@media (max-width: 768px) {
  .page_title {
    padding-left: var(--space-1);
  }
}
</style>