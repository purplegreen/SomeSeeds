---
interface Props {
  outcomes?: {
    label?: string
    url?: string
    internalRef?: { _type: string; title: string; slug: { current: string } }
  }[]
}

const { outcomes } = Astro.props
---

{outcomes && outcomes.length > 0 && (
  <section class="section">
    <h2 class="heading-m">Outcomes</h2>
    <ul class="outcomes-list">
      {outcomes.map(outcome => (
        <li class="outcome">
          {outcome.label && (
            <span class="outcome__label">{outcome.label}</span>
          )}
          {outcome.url && (
            
            <a  href={outcome.url}
              target="_blank"
              rel="noopener noreferrer"
              class="outcome__link underline-hover"
            >
              {outcome.url}
            </a>
          )}
          {outcome.internalRef && (
            
            <a  href={`/${outcome.internalRef._type}s/${outcome.internalRef.slug.current}`}
              class="outcome__link underline-hover"
            >
              {outcome.internalRef.title}
            </a>
          )}
        </li>
      ))}
    </ul>
  </section>
)}

<style>
.outcomes-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.outcome {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.outcome__label {
  font-size: var(--text-s);
  font-weight: 600;
}

.outcome__link {
  font-size: var(--text-s);
  opacity: 0.7;
}
</style>