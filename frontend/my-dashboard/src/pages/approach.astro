---
import { getSimplePage } from "../lib/sanity"
import PageHeader from "../components/sections/PageHeader.astro"
import Layout from "../layouts/Layout.astro"

const data = await getSimplePage("approach")
---

<Layout>
  <PageHeader 
    title={data?.title} 
    description={data?.description} 
    image={data?.image} 
    category={data?.category}
    tags={data?.tags}
    body={data?.body}
  />
</Layout>