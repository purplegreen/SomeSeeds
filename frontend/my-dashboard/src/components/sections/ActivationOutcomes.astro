---
interface Props {
  outcomes?: {
    label?: string
    url?: string
    internalRef?: { _type: string; title: string; slug: { current: string } }
  }[]
}

const { outcomes } = Astro.props
---

{outcomes && outcomes.length > 0 && (
  <section>
    <div class="container_grid">
    <h2 class="heading_l">Threads</h2>
    <ul class="outcomes-list">
      {outcomes.map(outcome => (
        <li class="outcome">
          {outcome.label && (
            <span class="outcome__label">{outcome.label}</span>
          )}
          {outcome.url && (
            
            <a  href={outcome.url}
              target="_blank"
              rel="noopener noreferrer"
              class="outcome__link underline-hover"
            >
              {outcome.url}
            </a>
          )}
          {outcome.internalRef && (
            
          <a  href={`/${outcome.internalRef._type}s/${outcome.internalRef.slug}`}
              class="outcome__link underline-hover"
            >
              {outcome.internalRef.title}
            </a>
          )}
        </li>
      ))}
    </ul>
    </div>
  </section>
)}

<style>

  .container_grid {
  display: grid;
  grid-template-columns: 15vw 15vw 1fr 1fr 1fr;
  grid-template-rows: 4rem auto;
  gap: 4rem 2rem;
  grid-template-areas:
    "a a-2 a-2 a-3 a-3"
    "a a-4 a-5 a-5 a-5";
  padding: var(--space-16) var(--space-4) 0 var(--space-4);
}

.heading_l {
  grid-area: a-2;
}

.outcomes-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  grid-area: a-5; 
}

.outcome {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.outcome__label {
  font-size: var(--text-m);
  font-weight: 600;
}

.outcome__link {
  font-size: var(--text-m);
  opacity: 0.7;
}
</style>