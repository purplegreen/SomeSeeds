---
import MobileMenu from "./MobileMenu.vue"
import ExplorationDropdown from "./ExplorationDropdown.vue"
import Button from '../ui/Button.vue'

interface Props {
  links: { label: string; href: string }[]
  logo?: string;
  currentPath: string;
  explorations?: { title: string; slug: string }[]
  ctaLink?: { label: string; href: string } | null
}
const { links, logo, currentPath: rawPath, explorations = [], ctaLink } = Astro.props;
const currentPath = rawPath.replace(/\/$/, "");

---

<header class="navbar">
  <div class="navbar__inner">

   <a href="/" class="navbar__logo">
  {logo ? <img src={logo} alt="Logo" /> : "SomeSeeds"}
</a>

    <!-- Desktop links -->
<nav class="navbar__links">
      {links.map(link => (
        link.href === "/explorations"
          ? <ExplorationDropdown
              client:load
              explorations={explorations}
              currentPath={currentPath}
              label={link.label}
            />
          : 
             <a href={link.href}
              class:list={["navbar__link", { "navbar__link--active": currentPath === link.href.replace(/\/$/, "") }]}
              aria-current={currentPath === link.href.replace(/\/$/, "") ? "page" : undefined}
            >
  {link.label}
</a>
  ))}
    {ctaLink && (
    <Button href={ctaLink.href} variant="secondary" size="sm" client:load>
      {ctaLink.label}
    </Button>
  )}
</nav>

<!-- Mobile menu -->
<MobileMenu client:load links={links} explorations={explorations} currentPath={currentPath} />

  </div>
</header>

<style>
  .navbar {
    display: flex;
    position: relative;
    top: 0.25rem;
    padding: 0 var(--space-4);
    width: 100%;
    z-index: 200;
  }

  .navbar__inner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0;
  z-index: 50;
}

.navbar__logo img {
  width: auto;
  height: 4 rem;
  padding-top: 0;
  z-index: 50;
}

.navbar__links {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 2rem;
  width: 100%;
  height: 100%;
    z-index: 50;
}

  .navbar__links a:not(.btn) {
    font-size: var(--text-s);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease; 
    align-items: center;
  }

  .navbar__links a:not(.btn):hover { 
    text-decoration: underline;
    text-underline-offset: var(--space-2);
    text-decoration-thickness: 3px;
  }
.navbar__links .navbar__link--active:not(.btn) {
  text-decoration: underline;
  text-decoration-color: var(--color-primary);
  text-underline-offset: var(--space-2);
  text-decoration-thickness: 3px;
}

  /* Hide desktop links on mobile */
  @media (max-width: 768px) {
    .navbar__links { display: none; }
  }
</style>
