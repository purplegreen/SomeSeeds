---
interface Props {
  label: string
  href?: string
}

const { label, href } = Astro.props
---

{href 
  ? <a href={href} class="category-tag">{label}</a>
  : <span class="category-tag">{label}</span>
}

<style>
.category-tag {
  display: inline-flex;
  align-items: center;
  font-size: var(--text-s);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.25rem 0.75rem;
  border: 2px solid var(--color-primary);
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.15s ease;
}

.category-tag:hover {
  opacity: 0.7;
}
</style>